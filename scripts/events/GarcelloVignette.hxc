import funkin.play.event.SongEvent;
import funkin.play.PlayState;
import funkin.graphics.FunkinSprite;
import funkin.Conductor;

import flixel.math.FlxMath;

class HazierGarcelloVignetteEvent extends SongEvent {
    function new()
    {
        super('HazierGarcelloVignetteEvent');
    }

    var pulseStrength:Float = 0;
    var pulseActive:Bool = false;
    var pulseSprite:FunkinSprite;

    function onDestroy()
    {
        pulseSprite = null;
    }

    function onSongRetry()
    {
        pulseSprite.alpha = 0;
        pulseActive = false;
    }

    function getTitle()
    {
        return 'Garello Vignette (Hazier River)';
    }

    function onCountdownStart()
    {
        if (pulseSprite != null) return;
        pulseSprite = FunkinSprite.create(0, 0, 'gameplay/garvignette'); pulseSprite.setGraphicSize(FlxG.width); pulseSprite.updateHitbox();
        PlayState.instance.add(pulseSprite); pulseSprite.camera = PlayState.instance.camCutscene; pulseSprite.alpha = 0.0001;
        pulseSprite.color = 0xFF00FF90;
    }

    function onUpdate(ev) {
        var zoomRate = PlayState.instance.cameraZoomRate;

        if (zoomRate > 0.0) {
            var decayRate:Float = 0.95;
            var dt:Float = ev.elapsed * 60;

            pulseSprite.alpha = FlxMath.lerp(0, pulseSprite.alpha, Math.pow(decayRate, dt));
        }
    }

    function onStepHit(ev) {
        if (!pulseActive) return;

        if (pulseStrength > 0 && (Conductor.instance.currentStep + PlayState.instance.cameraZoomRateOffset * Constants.STEPS_PER_BEAT) % (PlayState.instance.cameraZoomRate * Constants.STEPS_PER_BEAT) == 0) {
            pulseSprite.alpha += pulseStrength;
        }
    }

    override function handleEvent(ev)
    {
        var isActive = ev.getBool('isActive');
        var tempStrength = ev.getInt('strength');

        pulseActive = isActive;
        pulseStrength = tempStrength / 100;
    }

    function getEventSchema()
    {
        return [
            {
                name: 'isActive',
                title: 'Active?',
                defaultValue: false,
                type: 'bool'
            },
            {
                name: 'strength',
                title: 'Intensity',
                defaultValue: 20,
                type: 'integer',
                min: 0,
                max: 100,
                step: 5,
                units: '%'
            }
        ];
    }
}