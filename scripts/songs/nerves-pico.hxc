import funkin.audio.FunkinSound;
import funkin.util.SongSequence;
import funkin.util.HapticUtil;
import funkin.play.song.Song;
import funkin.play.PlayState;
import funkin.save.Save;
import funkin.Conductor;
import flixel.tweens.FlxTween;
import flixel.tweens.FlxEase;
import flixel.util.FlxTimer;

using StringTools;

class NervesPicoMixSong extends Song
{
  /**
   * The chance of Garcello being killed by Pico.
   * This is determined when you enter or restart the song.
   */
  public static final GARCELLO_KILL_CHANCE:Float = 8;

  /**
   * If we are currently awaitng Garcello's Death.
   */
  public var awaitingGarcelloDeath:Bool = false;

  /**
   * If Garcello is currently dead.
   */
  public var isGarcelloDead:Bool = false;

  public function new()
  {
    super('nerves',
      {
        variation: 'pico'
      });
  }

  override public function isSongNew(currentDifficulty:String, currentVariation:String):Bool
  {
    if (currentVariation == 'pico')
    {
      return !Save.instance.hasBeatenSong(this.id, null, this.variation);
    }

    return super.isSongNew(currentDifficulty, currentVariation);
  }

  /**
   * Garcello doesn't feel too well...
   * Let the player know when entering the song.
   */
  public function startGarcelloHurt():Void
  {
    FunkinSound.playOnce(Paths.sound('nervesouch'), 1.0);
    HapticUtil.vibrate(0.1, 0.5, 1, 1);
  }

  /**
   * Starts the conversation that happens when entering the song.
   */
  public function startConversation():Void
  {
    PlayState.instance?.startConversation('nerves-pico');
    PlayState.instance?.mayPauseGame = true;
  }

  /**
   * Gets the `SequenceEvent` list to use for lighting Garcello's cigarette.
   * This will not be executed if Garcello is already dead.
   *
   * @return Sequence List
   */
  public function getLightSequence():Array<SequenceEvent>
  {
    return [
      {
        time: getBeatTime(-2),
        callback: () -> {
          if (PlayState.instance?.camHUD == null) return;

          var duration:Float = -(Conductor.instance?.songPosition ?? 0);
          FlxTween.tween(PlayState.instance.camHUD, {alpha: 0}, -getBeatTime(-2));
        }
      },
      {
        time: getBeatTime(-1),
        callback: () -> {
          FunkinSound.playOnce(Paths.sound('Gun_Prep', 'weekend1'), 1);
          pico?.playAnimation('reload', true, false);

          var camX:Float = pico?.cameraFocusPoint?.x ?? 0;
          var camY:Float = pico?.cameraFocusPoint?.y ?? 0;
          PlayState.instance?.tweenCameraToPosition(camX + 150, camY + 150, 0.5, FlxEase.expoOut);
          PlayState.instance?.tweenCameraZoom(1.1, 0.5, false, FlxEase.expoOut);
        }
      },
      {
        time: 0,
        callback: () -> {
          pico?.playAnimation('cigshoot', true, false);
          garcello?.playAnimation('cig${awaitingGarcelloDeath ? 'miss' : 'light'}', true, false);
        }
      },
      {
        time: 0.45,
        callback: () -> {
          FunkinSound.playOnce(Paths.sound(awaitingGarcelloDeath ? 'lightmiss' : 'ciglight'), 1);
          HapticUtil.vibrate(0, 0.1, 0.1, 1);
          if (awaitingGarcelloDeath) killGarcello();
        }
      },
      {
        time: 1,
        callback: () -> {
          FunkinSound.playOnce(Paths.sound('spin and puff'), 1);
        }
      },
      {
        time: getBeatTime(6.50),
        callback: () -> {
          if (PlayState.instance?.camHUD != null)
          {
            FlxTween.tween(PlayState.instance.camHUD, {alpha: 1}, 0.9);
          }
        }
      },
    ];
  }

  /**
   * Kill Garcello.
   */
  public function killGarcello():Void
  {
    isGarcelloDead = true;

    PlayState.instance?.vocals?.opponentVolume = 0;
    PlayState.instance?.subtitles?.subtitlesData = null;
  }

  var hasPlayedCutscene:Bool = false;
  var sequence:SongSequence;

  override public function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);

    hasPlayedCutscene = false;

    // Seal Garcello's fate.
    awaitingGarcelloDeath = FlxG.random.bool(GARCELLO_KILL_CHANCE);
    isGarcelloDead = false;
  }

  override public function onCountdownStart(event:CountdownScriptEvent):Void
  {
    super.onCountdownStart(event);

    // Play the `cig-intro` animation unless Garcello is dead.
    if (!isGarcelloDead)
    {
      garcello?.playAnimation('cig-intro', true, false);
    }

    // Reset HUD opacity.
    if (PlayState.instance?.camHUD != null)
    {
      FlxTween.cancelTweensOf(PlayState.instance.camHUD);
      PlayState.instance.camHUD.alpha = 1;
    }

    // Don't play any cutscenes in the Chart Editor.
    if (PlayState.instance?.isChartingMode ?? false) return;

    if (!hasPlayedCutscene)
    {
      trace('Pausing countdown to play cutscene.');
      hasPlayedCutscene = true;

      PlayState.instance?.isInCutscene = true;
      PlayState.instance?.mayPauseGame = false;
      event.cancel();

      startGarcelloHurt();

      // Wait 1 second before playing the conversation..
      FlxTimer.wait(1, () -> startConversation());
    }
  }

  override public function onSongRetry(event:SongRetryEvent):Void
  {
    super.onSongRetry(event);

    if (isGarcelloDead)
    {
      // Make sure Garcello still shows dead when restarting.
      garcello?.playAnimation('cigmiss-hold', true, true);
    }
    else
    {
      // Allow a re-roll.
      awaitingGarcelloDeath = FlxG.random.bool(GARCELLO_KILL_CHANCE);
    }
  }

  override public function onSongStart(event:onSongStart):Void
  {
    // Make sure Garcello is still dead.
    if (isGarcelloDead) killGarcello();

    trace('Awaiting Death: ${awaitingGarcelloDeath}');
  }

  override public function onNoteHit(event:HitNoteScriptEvent)
  {
    if (isGarcelloDead && !event.note.noteData.getMustHitNote())
    {
      event.cancel();
    }

    super.onNoteHit(event);
  }

  override public function onSongLoaded(event:SongLoadScriptEvent):Void
  {
    sequence?.destroy();

    if (!isGarcelloDead)
    {
      var events:Array<SequenceEvent> = getLightSequence();
      sequence = new SongSequence(events);
      sequence.startTime = 0;
    }
  }

  override public function onDestroy(event:ScriptEvent):Void
  {
    super.onDestroy(event);

    sequence?.destroy();
    sequence = null;
  }

  // My favorite party trick:
  // Helper variables and function!
  var garcello(get, never):BaseCharacter;

  function get_garcello():BaseCharacter
  {
    return PlayState.instance?.currentStage?.getDad();
  }

  var pico(get, never):BaseCharacter;

  function get_pico():BaseCharacter
  {
    return PlayState.instance?.currentStage?.getBoyfriend();
  }

  function getBeatTime(beatTime:Float):Float
  {
    var beatTimeMs:Float = Conductor.instance?.getBeatTimeInMs(beatTime) ?? 0;
    return beatTimeMs / Constants.MS_PER_SEC;
  }
}
