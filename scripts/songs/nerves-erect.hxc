import funkin.play.song.Song;
import funkin.save.Save;

class NervesErectSong extends Song
{
  public function new()
  {
    super('nerves', {variation: 'erect'});
  }

  override public function isSongNew(currentDifficulty:String, currentVariation:String):Bool
  {
    if (currentVariation == 'erect')
    {
      return !Save.instance.hasBeatenSong(this.id, Constants.DEFAULT_DIFFICULTY_LIST_ERECT);
    }

    return super.isSongNew(currentDifficulty, currentVariation);
  }
}
