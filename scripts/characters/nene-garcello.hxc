import funkin.play.character.NeneBaseCharacter;

class NeneGarcelloCharacter extends NeneBaseCharacter
{
  public function new()
  {
    super('nene-garcello');
  }

  override public function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);
    abot.loadTextureAtlas('characters/abot/gar/abotSystem', 'shared');
  }

  override function setupAbot():Void
  {
    super.setupAbot();
    abot.y = y + 309 - (-globalOffsets[1] * scale.y);
  }
}
