import funkin.play.character.MultiAnimateAtlasCharacter;
import funkin.data.character.CharacterDataParser;
import funkin.play.PlayState;

class BoyfriendGarcelloCharacter extends MultiAnimateAtlasCharacter {
    function new() {
        super('bf-garcello');
    }

    var trailChar:BaseCharacter;
    
    function onCreate() {
        super.onCreate();

        if (this.debug) return; // "debug" means character/chart editor

        trailChar = CharacterDataParser.fetchCharacter('bf-trail');
        trailChar.alpha = 0.001; trailChar.color = 0xFFFFFF00;
        trailChar.flipX = false;
        currentStage.add(trailChar);

        FlxG.signals.postUpdate.addOnce(function () {
            trailChar.zIndex = this.zIndex - 5;
            currentStage.refresh(); // Apply z-index.
        });
    }

    function playAnimation(name:String, restart:Bool = false, ignoreOther:Bool = false, reversed:Bool = false) {
        super.playAnimation(name, restart, ignoreOther, reversed);

        if (trailChar != null) {
            trailChar.playAnimation(name, restart, ignoreOther);
            trailChar.setPosition(this.x + 35, this.y + 121);
        }
    }
}